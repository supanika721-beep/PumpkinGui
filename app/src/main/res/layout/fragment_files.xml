<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Breadcrumb bar -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@color/bg_secondary">

            <TextView
                android:id="@+id/tvBreadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="/ server"
                android:textColor="@color/accent_primary"
                android:textSize="12sp"
                android:typeface="monospace"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Folder action bar (clear logs / clear crash reports) -->
        <TextView
            android:id="@+id/btnFolderAction"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center"
            android:textColor="@color/status_stopped"
            android:textSize="12sp"
            android:background="#0D1117"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFiles"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="72dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabUpload"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_add"
        android:contentDescription="Upload file"
        app:backgroundTint="@color/accent_secondary"
        app:tint="#FFFFFF" />

</FrameLayout>
