<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- Toolbar — two-row layout so filename is never squeezed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B22"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Row 1: filename -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️  configuration.toml"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:typeface="monospace"
            android:layout_marginBottom="8dp" />

        <!-- Row 2: action buttons, right-aligned -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <TextView
                android:id="@+id/btnReloadConfig"
                android:layout_width="40dp"
                android:layout_height="34dp"
                android:text="↺"
                android:textSize="18sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:background="#21262D"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btnImportConfig"
                android:layout_width="40dp"
                android:layout_height="34dp"
                android:text="⬆️"
                android:textSize="16sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:background="#21262D"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btnSaveConfig"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="💾  Save"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="#238636" />
        </LinearLayout>
    </LinearLayout>

    <!-- Status message (shown when config not found) -->
    <TextView
        android:id="@+id/tvConfigStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textColor="#8B949E"
        android:textSize="13sp"
        android:padding="16dp"
        android:gravity="center" />

    <!-- Scrollable config rows -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/configContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp" />

    </ScrollView>

</LinearLayout>
