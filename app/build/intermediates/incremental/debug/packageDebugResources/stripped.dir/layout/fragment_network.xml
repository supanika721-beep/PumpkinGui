<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Local IP Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Header row: label + Copy button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌐  Local IP"
                        android:textColor="#8B949E"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <!-- Copy button (fitur baru) -->
                    <TextView
                        android:id="@+id/btnCopyLocalIp"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="⎘ Copy"
                        android:textColor="#8B949E"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="#21262D"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvLocalIpStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WiFi ●"
                        android:textColor="#50FA7B"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvLocalIp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textColor="#F0F6FC"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:typeface="monospace"
                    android:textIsSelectable="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Share this IP with players on the same network"
                    android:textColor="#6272A4"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Public IP Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Header row: label + toggle (gone until loaded) + refresh -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌍  Public IP"
                        android:textColor="#8B949E"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Toggle visibility: gone until IP loaded, restored via publicIpLoaded flag -->
                    <ImageButton
                        android:id="@+id/btnTogglePublicIp"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_secure"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="#8B949E"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/btnRefreshPublicIp"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="↺ Refresh"
                        android:textColor="#8B949E"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="#21262D" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPublicIp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textColor="#8B949E"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/tvPublicIpHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Internet-facing IP — tap 🔒 to reveal"
                    android:textColor="#6272A4"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ports Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔌  Server Ports"
                    android:textColor="#8B949E"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Java Edition"
                        android:textColor="#8BE9FD" android:textSize="14sp" />
                    <TextView android:id="@+id/tvJavaPort" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="25565"
                        android:textColor="#F1FA8C" android:textSize="14sp" android:typeface="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Bedrock Edition"
                        android:textColor="#8BE9FD" android:textSize="14sp" />
                    <TextView android:id="@+id/tvBedrockPort" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="19132"
                        android:textColor="#F1FA8C" android:textSize="14sp" android:typeface="monospace" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DuckDNS placeholder -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:alpha="0.45">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🦆  DuckDNS" android:textColor="#8B949E"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Coming soon — permanent hostname via dynamic DNS"
                    android:textColor="#6272A4" android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
