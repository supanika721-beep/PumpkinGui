<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Stats bar: CPU / RAM / PLAYERS / UPTIME -->
    <LinearLayout
        android:id="@+id/statsBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/bg_secondary"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CPU -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvCpu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/accent_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/progressCpu"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:progress="0"
                    android:progressTint="@color/accent_primary"
                    android:progressBackgroundTint="@color/divider" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="22dp"
            android:layout_marginHorizontal="8dp" android:background="@color/divider" />

        <!-- RAM -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RAM"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvRam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 MB"
                    android:textColor="@color/accent_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/progressRam"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:progress="0"
                    android:progressTint="@color/accent_primary"
                    android:progressBackgroundTint="@color/divider" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="22dp"
            android:layout_marginHorizontal="8dp" android:background="@color/divider" />

        <!-- PLAYERS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYERS"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
            <TextView
                android:id="@+id/tvPlayerCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/0"
                android:textColor="@color/accent_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:typeface="monospace" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="22dp"
            android:layout_marginHorizontal="8dp" android:background="@color/divider" />

        <!-- UPTIME -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPTIME"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:letterSpacing="0.08" />
            <TextView
                android:id="@+id/tvUptime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:typeface="monospace" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/statsDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/statsBar" />

    <!-- Search bar (hidden by default, slides in below stats) -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/statsDivider">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="13sp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Search logs…"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="13sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/tvSearchMatches"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnSearchPrev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/arrow_up_float"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleX="0.7" android:scaleY="0.7"
            app:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btnSearchNext"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/arrow_down_float"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleX="0.7" android:scaleY="0.7"
            app:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btnSearchClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleX="0.7" android:scaleY="0.7"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Log filter chips (hidden by default) -->
    <HorizontalScrollView
        android:id="@+id/filterBar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@color/bg_secondary"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchBar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="ALL"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@color/accent_secondary"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/chipInfo"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="INFO"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@color/bg_card"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/chipWarn"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="WARN"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@color/bg_card"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/chipError"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="ERROR"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@color/bg_card" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Terminal area -->
    <FrameLayout
        android:id="@+id/terminalContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/terminal_bg"
        app:layout_constraintTop_toBottomOf="@id/filterBar"
        app:layout_constraintBottom_toTopOf="@id/inputContainer">

        <com.termux.view.TerminalView
            android:id="@+id/terminalView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Filtered log view (shown when filter != ALL) -->
        <ScrollView
            android:id="@+id/filteredLogScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvFilteredLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:typeface="monospace"
                android:lineSpacingMultiplier="1.3" />
        </ScrollView>

        <!-- Toolbar overlay: search + filter toggles -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:orientation="horizontal"
            android:background="#BB0D1117">

            <ImageButton
                android:id="@+id/btnToggleSearch"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_search"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5dp"
                app:tint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btnToggleFilter"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5dp"
                app:tint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btnCopyLog"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5dp"
                app:tint="@color/text_secondary" />
        </LinearLayout>

    </FrameLayout>

    <!-- Bottom input container -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_secondary"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Pinned commands (hidden if empty) -->
        <HorizontalScrollView
            android:id="@+id/pinnedScroll"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/pinnedContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <!-- Command input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etCommand"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/bg_card"
                android:hint="Enter command…"
                android:imeOptions="actionSend"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="13sp"
                android:typeface="monospace" />

            <!-- History pair -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:background="@color/bg_card"
                android:layout_marginStart="6dp"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btnHistoryUp"
                    android:layout_width="34dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/arrow_up_float"
                    android:scaleX="0.6"
                    android:scaleY="0.6"
                    app:tint="@color/text_secondary" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="@color/divider" />

                <ImageButton
                    android:id="@+id/btnHistoryDown"
                    android:layout_width="34dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/arrow_down_float"
                    android:scaleX="0.6"
                    android:scaleY="0.6"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <!-- Pin command button -->
            <ImageButton
                android:id="@+id/btnPinCommand"
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:background="@color/bg_card"
                android:src="@android:drawable/btn_star_big_off"
                android:padding="10dp"
                app:tint="@color/text_secondary" />

            <!-- Send -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:background="@color/accent_secondary"
                android:src="@android:drawable/ic_menu_send"
                android:padding="10dp"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnStartStop"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="START SERVER"
                android:textSize="13sp"
                android:letterSpacing="0.04"
                android:backgroundTint="@color/status_running"
                android:textColor="#FFFFFF"
                app:cornerRadius="4dp" />

            <Button
                android:id="@+id/btnRestart"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:text="RESTART"
                android:textSize="12sp"
                android:backgroundTint="@color/bg_card"
                android:textColor="@color/text_secondary"
                app:cornerRadius="4dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
