<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_main">

        <!-- Top bar -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@color/bg_secondary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/tvPageTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Console"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTopBarLocalIp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Local IP: —"
                    android:textColor="@color/accent_primary"
                    android:textSize="10sp"
                    android:typeface="monospace" />
            </LinearLayout>

            <!-- Status dot: green = running, grey = stopped -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#484F58"
                android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- Subtle divider -->
        <View
            android:id="@+id/topBarDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/topBar" />

        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/topBarDivider"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <LinearLayout
        android:id="@+id/drawer"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/bg_secondary">

        <!-- Drawer header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="52dp"
            android:paddingBottom="16dp"
            android:background="@color/bg_main">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎃 Pumpkin"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Server Manager"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NAVIGATION"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/navConsole"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="   💻  Console"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/navFiles"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="   📂  Files"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/navConfig"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="   ⚙️  Config"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/navWorld"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="   🌍  World"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/navNetwork"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="   🌐  Network"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/navSettings"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="   ⚙️  Settings"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
