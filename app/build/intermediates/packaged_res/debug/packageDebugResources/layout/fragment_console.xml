<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- Control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#161B22"
        android:padding="10dp">

        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="▶ Start"
            android:textColor="#FFFFFF"
            android:backgroundTint="#238636"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRestart"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="↺ Restart"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9E6A03"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Stats -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B22"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_marginTop="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="5dp">

            <TextView
                android:id="@+id/tvCpu"
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:text="CPU:  0.00%"
                android:textColor="#8BE9FD"
                android:textSize="12sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <ProgressBar
                android:id="@+id/progressCpu"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="10dp"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="#8BE9FD"
                android:progressBackgroundTint="#30363D" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvRam"
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:text="RAM:  0 MB"
                android:textColor="#FFB86C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <ProgressBar
                android:id="@+id/progressRam"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="10dp"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="#FFB86C"
                android:progressBackgroundTint="#30363D" />
        </LinearLayout>
    </LinearLayout>

    <!-- Players -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B22"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvPlayerCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Players Online: 0"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlayers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>

    <!-- Console label + copy -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#0D1117"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CONSOLE"
            android:textColor="#8B949E"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCopyLog"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="📋 Copy"
            android:textColor="#8B949E"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="#21262D" />
    </LinearLayout>

    <!-- TerminalView — renders ANSI natively like Termux -->
    <com.termux.view.TerminalView
        android:id="@+id/terminalView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D1117"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <!-- Command bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#161B22"
        android:padding="8dp">

        <EditText
            android:id="@+id/etCommand"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Type command..."
            android:textColor="#F0F6FC"
            android:textColorHint="#8B949E"
            android:textSize="13sp"
            android:typeface="monospace"
            android:background="#21262D"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="Send"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1F6FEB"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
