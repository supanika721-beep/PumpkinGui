<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Breadcrumb path -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#161B22"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvBreadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/ server"
                android:textColor="#8BE9FD"
                android:textSize="12sp"
                android:typeface="monospace" />
        </HorizontalScrollView>

        <!-- Folder action bar: shown only inside logs/ and crash-reports/ -->
        <TextView
            android:id="@+id/btnFolderAction"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:gravity="center"
            android:textColor="#FF5555"
            android:textSize="12sp"
            android:background="#1A0000"
            android:visibility="gone" />

        <!-- File list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFiles"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0D1117"
            android:paddingBottom="80dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- FAB Upload - xmlns:app di root bukan di sini -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabUpload"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_add"
        android:contentDescription="Upload file"
        app:backgroundTint="#1F6FEB"
        app:tint="#FFFFFF" />

</FrameLayout>
